---
import { Image } from "astro:assets";
import { DEFAULT_PLACEHOLDER_IMAGE } from "@/consts/blurImage";

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  blurDataURL?: string;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  blurDataURL = DEFAULT_PLACEHOLDER_IMAGE,
  class: className,
} = Astro.props;
---

<div class:list={["relative overflow-hidden", className]}>
  <!-- Placeholder -->
  <img src={blurDataURL} alt="" aria-hidden="true" class="placeholder" />

  <!-- Main image -->
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    class="main-image"
    loading="lazy"
    onload="this.classList.add('loaded')"
  />
</div>

<style>
  div {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(20px);
    transform: scale(1.05);
    transition: opacity 0.3s ease-in-out;
  }

  .main-image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }

  .main-image.loaded {
    opacity: 1;
  }

  .main-image.loaded + .placeholder,
  .main-image.loaded ~ .placeholder {
    opacity: 0;
  }
</style>
